{% extends "layouts.master" %}

{% block content %}
<section class="siah-hero">
  <div class="container">
    <div class="siah-hero__grid">

      <div class="siah-hero__content">
        <span class="siah-hero__eyebrow">Siah Theme</span>

        <h1 class="siah-hero__title">
          تصميم عربي أولاً
          <span>لتجربة تسوق أكثر أناقة</span>
        </h1>

        <p class="siah-hero__text">
          ثيم احترافي لمتاجر سلة يجمع بين البساطة الراقية والمرونة التجارية،
          ليمنح المتجر حضورًا بصريًا قويًا وتجربة استخدام مريحة على جميع الأجهزة.
        </p>

        <div class="siah-hero__actions">
          <a href="#" class="siah-btn siah-btn--primary">ابدأ التسوق</a>
          <a href="#" class="siah-btn siah-btn--secondary">استكشف الأقسام</a>
        </div>
      </div>

      <div class="siah-hero__visual">
        <div class="siah-hero__card">
          <div class="siah-hero__media">
            <div class="siah-hero__media-inner"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<section class="siah-categories">
  <div class="container">
    <div class="siah-section-head">
      <div>
        <span class="siah-section-head__eyebrow">التسوق حسب الفئة</span>
        <h2 class="siah-section-head__title">اكتشف الأقسام المميزة</h2>
      </div>

      <a href="#" class="siah-section-head__link">عرض الكل</a>
    </div>

    <div class="siah-categories__grid">
      <a href="#" class="siah-category-card">
        <div class="siah-category-card__media"></div>
        <div class="siah-category-card__content">
          <h3 class="siah-category-card__title">العبايات</h3>
          <p class="siah-category-card__meta">تصاميم يومية ومناسبة</p>
        </div>
      </a>

      <a href="#" class="siah-category-card">
        <div class="siah-category-card__media"></div>
        <div class="siah-category-card__content">
          <h3 class="siah-category-card__title">العطور</h3>
          <p class="siah-category-card__meta">روائح فاخرة مختارة</p>
        </div>
      </a>

      <a href="#" class="siah-category-card">
        <div class="siah-category-card__media"></div>
        <div class="siah-category-card__content">
          <h3 class="siah-category-card__title">الإكسسوارات</h3>
          <p class="siah-category-card__meta">تفاصيل تكمل الإطلالة</p>
        </div>
      </a>

      <a href="#" class="siah-category-card">
        <div class="siah-category-card__media"></div>
        <div class="siah-category-card__content">
          <h3 class="siah-category-card__title">الهدايا</h3>
          <p class="siah-category-card__meta">خيارات أنيقة للمناسبات</p>
        </div>
      </a>
    </div>
  </div>
</section>

<section class="siah-featured-products">
  <div class="container">
    <div class="siah-section-head">
      <div>
        <span class="siah-section-head__eyebrow">منتجات مختارة</span>
        <h2 class="siah-section-head__title">الأكثر طلبًا هذا الأسبوع</h2>
      </div>

      <a href="#" class="siah-section-head__link">عرض الكل</a>
    </div>

    <div class="siah-products-grid">
      <article class="siah-product-card">
        <a href="#" class="siah-product-card__media-wrap">
          <span class="siah-product-card__badge">جديد</span>
          <div class="siah-product-card__media"></div>
        </a>

        <div class="siah-product-card__content">
          <p class="siah-product-card__category">عبايات</p>
          <h3 class="siah-product-card__title">
            <a href="#">عباية سوداء بتفاصيل ناعمة</a>
          </h3>

          <div class="siah-product-card__price">
            <span class="siah-product-card__price-current">289 ر.س</span>
            <span class="siah-product-card__price-old">349 ر.س</span>
          </div>

          <a href="#" class="siah-btn siah-btn--secondary siah-product-card__cta">
            أضف إلى السلة
          </a>
        </div>
      </article>

      <article class="siah-product-card">
        <a href="#" class="siah-product-card__media-wrap">
          <span class="siah-product-card__badge">الأكثر مبيعًا</span>
          <div class="siah-product-card__media"></div>
        </a>

        <div class="siah-product-card__content">
          <p class="siah-product-card__category">عطور</p>
          <h3 class="siah-product-card__title">
            <a href="#">عطر شرقي بلمسة خشبية دافئة</a>
          </h3>

          <div class="siah-product-card__price">
            <span class="siah-product-card__price-current">199 ر.س</span>
          </div>

          <a href="#" class="siah-btn siah-btn--secondary siah-product-card__cta">
            أضف إلى السلة
          </a>
        </div>
      </article>

      <article class="siah-product-card">
        <a href="#" class="siah-product-card__media-wrap">
          <span class="siah-product-card__badge">خصم 20%</span>
          <div class="siah-product-card__media"></div>
        </a>

        <div class="siah-product-card__content">
          <p class="siah-product-card__category">إكسسوارات</p>
          <h3 class="siah-product-card__title">
            <a href="#">حقيبة صغيرة بتصميم يومي أنيق</a>
          </h3>

          <div class="siah-product-card__price">
            <span class="siah-product-card__price-current">159 ر.س</span>
            <span class="siah-product-card__price-old">199 ر.س</span>
          </div>

          <a href="#" class="siah-btn siah-btn--secondary siah-product-card__cta">
            أضف إلى السلة
          </a>
        </div>
      </article>

      <article class="siah-product-card">
        <a href="#" class="siah-product-card__media-wrap">
          <span class="siah-product-card__badge">محدود</span>
          <div class="siah-product-card__media"></div>
        </a>

        <div class="siah-product-card__content">
          <p class="siah-product-card__category">هدايا</p>
          <h3 class="siah-product-card__title">
            <a href="#">صندوق هدايا فاخر بتغليف مميز</a>
          </h3>

          <div class="siah-product-card__price">
            <span class="siah-product-card__price-current">249 ر.س</span>
          </div>

          <a href="#" class="siah-btn siah-btn--secondary siah-product-card__cta">
            أضف إلى السلة
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="siah-editorial">
  <div class="container">
    <div class="siah-editorial__grid">

      <div class="siah-editorial__media">
        <div class="siah-editorial__media-inner"></div>
      </div>

      <div class="siah-editorial__content">
        <span class="siah-editorial__eyebrow">قصة العلامة</span>

        <h2 class="siah-editorial__title">
          تفاصيل مصممة لتمنح المتجر
          <span>حضورًا أكثر تميزًا</span>
        </h2>

        <p class="siah-editorial__text">
          صُمم Siah ليمنح العلامات التجارية مساحة بصرية أهدأ وأكثر أناقة،
          مع بنية مرنة تساعد على إبراز المنتجات، العروض، والمحتوى التحريري
          بطريقة متوازنة ومريحة للزائر.
        </p>

        <a href="#" class="siah-btn siah-btn--primary">اقرأ المزيد</a>
      </div>

    </div>
  </div>
</section>

<section class="siah-trust">
  <div class="container">
    <div class="siah-trust__grid">

      <div class="siah-trust__item">
        <div class="siah-trust__icon">
          <i class="sicon-shipping-fast"></i>
        </div>
        <div class="siah-trust__content">
          <h3 class="siah-trust__title">شحن سريع</h3>
          <p class="siah-trust__text">توصيل موثوق وسريع إلى مختلف المناطق.</p>
        </div>
      </div>

      <div class="siah-trust__item">
        <div class="siah-trust__icon">
          <i class="sicon-secure"></i>
        </div>
        <div class="siah-trust__content">
          <h3 class="siah-trust__title">دفع آمن</h3>
          <p class="siah-trust__text">خيارات دفع متعددة وتجربة شراء آمنة.</p>
        </div>
      </div>

      <div class="siah-trust__item">
        <div class="siah-trust__icon">
          <i class="sicon-headphone"></i>
        </div>
        <div class="siah-trust__content">
          <h3 class="siah-trust__title">دعم متواصل</h3>
          <p class="siah-trust__text">فريق جاهز لمساعدتك والإجابة على استفساراتك.</p>
        </div>
      </div>

      <div class="siah-trust__item">
        <div class="siah-trust__icon">
          <i class="sicon-refresh"></i>
        </div>
        <div class="siah-trust__content">
          <h3 class="siah-trust__title">استبدال مرن</h3>
          <p class="siah-trust__text">سياسات واضحة لراحة أكبر أثناء التسوق.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<section class="siah-testimonials">
  <div class="container">
    <div class="siah-section-head siah-section-head--center">
      <div>
        <span class="siah-section-head__eyebrow">آراء العملاء</span>
        <h2 class="siah-section-head__title">تجارب حقيقية تزيد الثقة</h2>
      </div>
    </div>

    <div class="siah-testimonials__grid">
      <article class="siah-testimonial-card">
        <div class="siah-testimonial-card__stars">★★★★★</div>
        <p class="siah-testimonial-card__text">
          تجربة جميلة جدًا من ناحية سهولة التصفح وسرعة الطلب، والمنتج وصل بشكل أنيق ومرتب.
        </p>
        <div class="siah-testimonial-card__author">
          <strong>نورة عبدالله</strong>
          <span>عميلة موثقة</span>
        </div>
      </article>

      <article class="siah-testimonial-card">
        <div class="siah-testimonial-card__stars">★★★★★</div>
        <p class="siah-testimonial-card__text">
          أكثر شيء أعجبني هو وضوح الأقسام وسهولة الوصول للمنتجات، التصميم فعلًا مريح ويشجع على الشراء.
        </p>
        <div class="siah-testimonial-card__author">
          <strong>سارة محمد</strong>
          <span>عميلة متكررة</span>
        </div>
      </article>

      <article class="siah-testimonial-card">
        <div class="siah-testimonial-card__stars">★★★★★</div>
        <p class="siah-testimonial-card__text">
          المتجر يبدو احترافيًا جدًا، والتنظيم ممتاز، وهذا أعطاني ثقة أكبر في الطلب من أول زيارة.
        </p>
        <div class="siah-testimonial-card__author">
          <strong>ريم خالد</strong>
          <span>طلب جديد</span>
        </div>
      </article>
    </div>
  </div>
</section>
{% endblock %}