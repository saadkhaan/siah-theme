<footer class="siah-footer border-t mt-16">
  <div class="container py-10">

    <div class="grid md:grid-cols-3 gap-8 text-center md:text-left">

      {# Store Info #}
      <div>
        <h3 class="font-semibold text-lg mb-3">{{ store.name }}</h3>

        {% if store.description %}
          <p class="text-sm text-gray-500 leading-6">
            {{ store.description|striptags }}
          </p>
        {% endif %}
      </div>

      {# Links #}
      <div>
        <h4 class="font-medium mb-3">Links</h4>
        <salla-menu source="footer"></salla-menu>
      </div>

      {# Social #}
      <div>
        <h4 class="font-medium mb-3">Follow us</h4>
        <salla-social></salla-social>
      </div>

    </div>

    {# Bottom Bar #}
    <div class="mt-10 pt-6 border-t flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-500">

      <span>{% hook copyright %}</span>

      <salla-payments></salla-payments>

    </div>

  </div>
</footer>