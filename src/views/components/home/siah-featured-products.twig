{% set products = component.products %}
{% set title = component.title %}
{% set subtitle = component.subtitle %}

<section class="siah-featured-products">
  <div class="container">
    <div class="siah-section-head">
      <div>
        {% if subtitle %}
          <span class="siah-section-head__eyebrow">{{ subtitle }}</span>
        {% endif %}

        {% if title %}
          <h2 class="siah-section-head__title">{{ title }}</h2>
        {% endif %}
      </div>
    </div>

    {% if products and products|length %}
      <div class="siah-products-grid">
        {% for product in products %}
          <article class="siah-product-card">
            <a href="{{ product.url }}" class="siah-product-card__media-wrap">
              {% if product.is_on_sale %}
                <span class="siah-product-card__badge">خصم</span>
              {% elseif product.is_new %}
                <span class="siah-product-card__badge">جديد</span>
              {% endif %}

              <div class="siah-product-card__media">
                {% set image_url = null %}

                {% if product.image is defined and product.image %}
                  {% if product.image.url is defined and product.image.url %}
                    {% set image_url = product.image.url %}
                  {% else %}
                    {% set image_url = product.image %}
                  {% endif %}
                {% elseif product.main_image is defined and product.main_image %}
                  {% if product.main_image.url is defined and product.main_image.url %}
                    {% set image_url = product.main_image.url %}
                  {% else %}
                    {% set image_url = product.main_image %}
                  {% endif %}
                {% elseif product.images is defined and product.images and product.images[0] is defined %}
                  {% if product.images[0].url is defined and product.images[0].url %}
                    {% set image_url = product.images[0].url %}
                  {% else %}
                    {% set image_url = product.images[0] %}
                  {% endif %}
                {% endif %}

                {% if image_url %}
                  <img src="{{ image_url }}" alt="{{ product.name }}" loading="lazy">
                {% else %}
                  <pre style="font-size:12px; direction:ltr; text-align:left; white-space:pre-wrap; padding:12px; overflow:auto;">{{ product|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                {% endif %}
              </div>
            </a>

            <div class="siah-product-card__content">
              {% if product.category and product.category.name %}
                <p class="siah-product-card__category">{{ product.category.name }}</p>
              {% endif %}

              <h3 class="siah-product-card__title">
                <a href="{{ product.url }}">{{ product.name }}</a>
              </h3>

              <div class="siah-product-card__price">
                {% if product.sale_price %}
                  <span class="siah-product-card__price-current">{{ product.sale_price }}</span>
                  {% if product.regular_price %}
                    <span class="siah-product-card__price-old">{{ product.regular_price }}</span>
                  {% endif %}
                {% else %}
                  <span class="siah-product-card__price-current">{{ product.price }}</span>
                {% endif %}
              </div>

              <a href="{{ product.url }}" class="siah-btn siah-btn--secondary siah-product-card__cta">
                عرض المنتج
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="siah-empty-state">
        <p>اختر منتجات لعرضها في هذا القسم.</p>
      </div>
    {% endif %}
  </div>
</section>