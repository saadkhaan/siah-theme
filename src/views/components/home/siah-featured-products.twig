{% set products = component.products|default([]) %}
{% set title = component.title|default('Featured products') %}
{% set subtitle = component.subtitle|default('منتجات مختارة') %}

<section class="siah-featured-products">
  <div class="container">
    <div class="siah-section-head">
      <div>
        <span class="siah-section-head__eyebrow">{{ subtitle }}</span>
        <h2 class="siah-section-head__title">{{ title }}</h2>
      </div>
    </div>

    {% if products|length > 0 %}
      <div class="siah-products-grid">
        {% for product in products %}
          {% set image_url = null %}

          {# image can be string, object, or array #}
          {% if product.image is defined and product.image %}
            {% if product.image is iterable %}
              {% if product.image.url is defined and product.image.url %}
                {% set image_url = product.image.url %}
              {% elseif product.image[0] is defined %}
                {% if product.image[0].url is defined and product.image[0].url %}
                  {% set image_url = product.image[0].url %}
                {% elseif product.image[0] is not iterable %}
                  {% set image_url = product.image[0] %}
                {% endif %}
              {% endif %}
            {% else %}
              {% set image_url = product.image %}
            {% endif %}
          {% elseif product.main_image is defined and product.main_image %}
            {% if product.main_image is iterable %}
              {% if product.main_image.url is defined and product.main_image.url %}
                {% set image_url = product.main_image.url %}
              {% endif %}
            {% else %}
              {% set image_url = product.main_image %}
            {% endif %}
          {% elseif product.images is defined and product.images and product.images[0] is defined %}
            {% if product.images[0] is iterable %}
              {% if product.images[0].url is defined and product.images[0].url %}
                {% set image_url = product.images[0].url %}
              {% endif %}
            {% else %}
              {% set image_url = product.images[0] %}
            {% endif %}
          {% endif %}

          {% set current_price = product.price|default(null) %}
{% set old_price = null %}

{% if product.regular_price is defined and product.regular_price and product.regular_price != current_price %}
  {% set old_price = product.regular_price %}
{% elseif product.sale_price is defined and product.sale_price and product.sale_price != 0 and product.sale_price != '0' and product.sale_price != current_price %}
  {% set old_price = product.sale_price %}
{% endif %}

<div class="siah-product-card__price">
  {% if old_price %}
    <span class="siah-product-card__price-old">{{ old_price }}</span>
  {% endif %}

  <span class="siah-product-card__price-current">
    {{ current_price|default('—') }}
  </span>
</div>
        {% endfor %}
      </div>
    {% else %}
      <div class="siah-empty-state">
        <p>اختر منتجات لعرضها في هذا القسم.</p>
      </div>
    {% endif %}
  </div>
</section>