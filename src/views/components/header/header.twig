<header class="siah-header border-b">
  <div class="container flex items-center justify-between py-4">

    {# Logo #}
    <a href="{{ store.url }}" class="siah-logo flex items-center gap-2">
      <img src="{{ store.logo|cdn(120) }}" alt="{{ store.name }}" class="h-8 w-auto">
      <span class="sr-only">{{ store.name }}</span>
    </a>

    {# Right Side #}
    <div class="flex items-center gap-4">

      {# Search #}
      <div class="hidden md:block">
        <salla-search inline></salla-search>
      </div>

      {# User #}
      {% if user.type == 'user' %}
        <salla-user-menu avatar-only></salla-user-menu>
      {% else %}
        <button onclick="salla.event.dispatch('login::open')" class="siah-icon-btn">
          <i class="sicon-user-circle text-xl"></i>
        </button>
      {% endif %}

      {# Cart #}
      <salla-cart-summary>
        <i slot="icon" class="sicon-shopping-bag text-xl"></i>
      </salla-cart-summary>

    </div>
  </div>
</header>